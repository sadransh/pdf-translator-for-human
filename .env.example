# OpenAI-compatible API configuration
OPENAI_API_KEY=your-api-key-here
# OPENAI_API_BASE=https://api.openai.com/v1          # OpenAI
# OPENAI_API_BASE=https://api.deepseek.com/v1       # DeepSeek
# OPENAI_API_BASE=https://api.moonshot.cn/v1         # Moonshot
# OPENAI_API_BASE=http://localhost:11434/v1          # Ollama (default port)
# OPENAI_API_BASE=http://localhost:8080/v1            # llama.cpp / mlx_lm
OPENAI_API_BASE=http://localhost:11434/v1

# Default translation model
OPENAI_MODEL=translategemma:12b
DEFAULT_MODEL=translategemma:12b

# PDF Parser Mode: legacy, docling (default), hybrid, legacyocr, easyocr
# legacy    = pymupdf only (fastest, may have encoding issues with some PDFs)
# docling   = AI-based OCR (requires docling package, best quality)
# hybrid    = try legacy first, fallback to docling if garbled text detected
# legacyocr = try legacy first, fallback to pymupdf's built-in tesseract OCR
# easyocr   = try legacy first, fallback to easyOCR
PDF_PARSER_MODE=docling

# Optional: comma-separated list of additional models to show in the UI dropdown
# AVAILABLE_MODELS=gpt-4o-mini,translategemma:12b,llama3.1:8b

# Optional: bbox expansion factor for translated text (default: 1.15)
# BBOX_EXPANSION_FACTOR=1.15

# Optional: minimum spacing between translated blocks (default: 8.0)
# MIN_SPACING=8.0

# Optional: enable/disable collision detection (default: true)
# COLLISION_DETECTION_ENABLED=true